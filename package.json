{
  "name": "serverless-images-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply serverless-images-api --local",
    "migrate:remote": "wrangler d1 migrations apply serverless-images-api --remote",
    "deploy": "pnpm run migrate:remote && pnpm run build && wrangler deploy",
    "preview": "pnpm run build && wrangler preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "cf-typegen": "wrangler types",
    "prepare": "husky && pnpm run migrate:local"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cloudflare/vite-plugin": "^1.45.0",
    "@orpc/openapi": "^1.14.8",
    "@orpc/server": "^1.14.8",
    "@orpc/zod": "^1.14.8",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.7.11",
    "@tanstack/react-form-start": "^1.33.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.28",
    "@tanstack/router-plugin": "^1.168.20",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "kysely": "^0.29.3",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.545.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "packageManager": "pnpm@11.13.0"
}
